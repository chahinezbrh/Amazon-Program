generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url = env("DATABASE_URL") // to generate a database for each repo 
}


//a function indexed from the codebase

model FunctionRecord {

  id           String  @id @default(uuid())
  name         String 
  filePath     String
  lineStart    Int 
  lineEnd      Int

  hash         String
  previousHash String? //the ? means it can be null if there is no ? it means it can t be ull

  aiDocumentation String?
  aiGeneratedAt   DateTime? 

  confidence     String @default("AI_ONLY") 
  
  //to indicate whether the documentation is ai written or human 
  // check the enum part at the end of the file 
  
  author String? 

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @default(now())

  memories    Memory[]  //one function can have multiple recordings attached to it 
  alerts      MemoryAlert[]  //also here it can have multiple alerts 

  @@unique([filePath , name , lineStart]) //avoid duplicate entries for the same function

}

// the recorded memory 

model Memory {

  id   String  @id  @default(uuid())

  functionId  String
  function    FunctionRecord  @relation(fields: [functionId], references: [id]) //like the foreign key in sql

  author          String 
  audioUrl        String 
  durationSec     Int?
  transcript      String?
  RecordedAt      DateTime @default(now())
  hashAtRecording String

  isStale Boolean  @default(false)   
  //this field when there is a change and the hash is changed in this case there will be 
  //a mistamch between the recording of the function and the new function code
  //in this case this field turns to true after the comparison between the two hahses
  //useful when we want to list the recordings of the function 


}


//the memoryAlert

model MemoryAlert{

  id   String  @id @default(uuid())

  functionId   String 
  function     FunctionRecord   @relation(fields: [functionId] , references: [id])

  severity     String  @default("WARNING")
  reason       String     //to indicate whether it is logic or syntaxic 
  oldHash      String
  newHash      String

  status     String  @default("OPEN")
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?  

}



//storing the new and the old hash to avoid the seperate lookup so we use one query

//storing the hashAtrecording : because when receiving a change from the webhook 
//and we recompoute the hash we compare it against the hashatrecording becasue the function
//can have multiple memories over time 